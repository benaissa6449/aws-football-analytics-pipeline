# Configuration pour AWS Pipeline - Football Goals Streaming
# À copier dans Cloud9 ou ajouter au Terminal

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Kinesis Configuration
KINESIS_STREAM_NAME=goals-stream
KINESIS_PARTITION_KEY=match_id

# Firehose Configuration
FIREHOSE_DELIVERY_STREAM_NAME=goals-firehose

# S3 Configuration
S3_BUCKET_NAME=foot-data-bucket
S3_PREFIX=goals_raw/

# Logging Configuration
LOG_LEVEL=INFO

# Script Configuration
BATCH_SIZE=1  # Nombre de matchs à traiter en parallèle
DELAY_BETWEEN_MATCHES=0  # Délai en secondes entre chaque match (0 = pas de délai)
DELAY_BETWEEN_GOALS=0.1  # Délai en secondes entre chaque but (simule le streaming)

# Development
DEBUG=False
